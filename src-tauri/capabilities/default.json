{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and widget windows",
  "windows": ["main", "widget-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-resize-dragging",
    "opener:default",
    "notification:default",
    "dialog:default"
  ]
}
